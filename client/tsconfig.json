{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    
    "module": "ESNext",
    "moduleResolution": "node",

    "jsx": "react-jsx",

    "strict": false,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "shared": ["../shared"],
      "shared/*": ["../shared/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}